<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/l1_bg"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/l1_reminder_message"
        android:textColor="@color/l1_text"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnOk"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/key_special_background"
        android:paddingHorizontal="12dp"
        android:text="@string/l1_btn_ok"
        android:textColor="@color/l1_text"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnDismiss"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:text="@string/l1_btn_dismiss"
        android:textColor="@color/key_special_text"
        android:textSize="12sp" />

</LinearLayout>
