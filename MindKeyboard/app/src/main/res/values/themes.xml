<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MindKeyboard" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/purple_700</item>
    </style>

    <!-- 键盘按键样式 -->
    <style name="KeyStyle">
        <item name="android:background">@drawable/key_background</item>
        <item name="android:textColor">@color/key_text</item>
        <item name="android:textSize">20sp</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="KeyStyle.Special">
        <item name="android:background">@drawable/key_special_background</item>
        <item name="android:textColor">@color/key_special_text</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
